# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit secrets.

# EIA Open Data API key — get a free one at https://www.eia.gov/opendata/
EIA_API_KEY=

# PostgreSQL (defaults match what the codebase expects; override if needed)
PG_HOST=localhost
PG_PORT=5432
PG_DB=eia_crude
PG_USER=eia_user
PG_PASS=eia_password
PG_SCHEMA=oil_network_data_loader
