  "meta": {
    "schema_version": "v1.0",
    "description": "Deterministic seed list for production_sites.field. Replaces the agent-driven bootstrap_seed_async() pass with a hand-curated JSON, mirroring how Stage 1 loaded refineries from the EIA Refinery Capacity Report. Identification-level data only (name, basin, play, field_type, onshore/offshore, current operator). Per-field deep research — production history, reserves, events, logistics — is left to the explorer agent.",
    "authoritative_sources": [
      "EIA “Top 100 Oil and Gas Fields” (last published 2015; useful for conventional ranking but pre-dates the modern shale build-out)",
      "EIA “U.S. Crude Oil and Natural Gas Proved Reserves” annual reports",
      "Texas Railroad Commission (TX RRC) field master list — Permian + Eagle Ford",
      "North Dakota DMR — Bakken / Three Forks field roster",
      "Alaska AOGCC — North Slope + Cook Inlet field list",
      "Colorado COGCC / ECMC — DJ / Niobrara",
      "New Mexico OCD — Delaware Basin",
      "Wyoming WOGCC — Powder River + Greater Green River",
      "Oklahoma OCC — Anadarko / SCOOP / STACK",
      "California CalGEM — San Joaquin + LA basin",
      "BSEE Field Master — Federal Gulf of Mexico"
    ],
    "treatment_note": "Tight-oil and shale plays do not have meaningful per-field identity at the well level (continuous resource plays). They are seeded here at the sub-play / unit level (e.g. spraberry_trend_tx, wolfcamp_midland_tx, bone_spring_nm) as that is how EIA and state regulators aggregate them. Named conventional traps (Wasson, Yates, Prudhoe Bay, Mars-Ursa) are seeded at trap level.",
    "operator_note": "current_operator is best-known at time of curation; ownership changes frequently. For shale-play units with many operators the field is marked 'various'. The explorer agent's record_operator pass establishes the authoritative operator history.",
    "coverage_targets_remaining": [
      "Additional Permian conventional fields (long tail of smaller TX/NM traps)",
      "Additional GoM shelf fields (Eugene Island, South Pass, West Cameron — most are gas-condensate now)",
      "Smaller Appalachian/Illinois Basin/Michigan fields"
    ],
    "field_count": 136,
    "curated_by": "Claude + Pedro, 2026-05-26",
    "schema_per_entry": {
      "id":                "stable slug — also becomes production_sites.field.field_id",
      "name":              "marketed/regulator name",
      "state":             "2-letter USPS code, or 'GoM' for federal Gulf, 'Pacific' for federal offshore Pacific",
      "basin":             "Permian | Williston | Eagle Ford | DJ/Niobrara | Anadarko/SCOOP/STACK | Powder River | Uinta | Piceance | Hugoton/Panoma | San Joaquin | Los Angeles | Salinas | Alaska North Slope | Alaska Cook Inlet | Gulf of Mexico | Appalachian | Other",
      "play":              "sub-formation or marketed grade-bearing play",
      "field_type":        "conventional | tight-oil | shale | heavy-oil | oil-sands | offshore-deepwater | offshore-shelf | arctic",
      "onshore_offshore":  "onshore | offshore",
      "current_operator":  "best-known operator name, or 'various'/'multiple' for shale-play units",
      "rank_notes":        "free-form context — discovery year, notable production status, EOR techniques, named-grade output"
    }
  },

