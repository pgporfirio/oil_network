{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "Edit(*)",
      "Write(*)",
      "Read(*)",
      "NotebookEdit(*)",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "Skill(*)"
    ]
  },
  "autoMemoryDirectory": "./.claude/memory",
  "effortLevel": "xhigh",
  "autoUpdatesChannel": "latest"
}
